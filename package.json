{
  "name": "observability-platform",
  "version": "0.1.0",
  "description": "Multi-tenant observability platform for n8n automations",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:worker": "tsc",
    "start:worker": "node dist/index.js",
    "migrate": "node-pg-migrate --envPath .env --tsx",
    "migrate:prod": "node-pg-migrate --tsx",
    "derive:backfill": "tsx src/scripts/deriveBackfill.ts",
    "link:founder": "tsx src/scripts/linkFounder.ts",
    "web": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "build:web": "cd web && npm run build",
    "start:web": "cd web && npm run start",
    "web:install": "cd web && npm install"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
