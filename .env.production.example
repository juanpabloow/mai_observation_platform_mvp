# ============================================================================
# PRODUCTION environment variables (Railway). PLACEHOLDERS ONLY — set the real
# values in each Railway service's "Variables" tab. NEVER commit real secrets.
#
# Generate FRESH secrets for production — do NOT reuse your local dev values.
# This file documents what each of the three services needs.
# ============================================================================

# ----------------------------------------------------------------------------
# SHARED — set on BOTH the `web` and `worker` services with IDENTICAL values
# ----------------------------------------------------------------------------

# Postgres connection string. In Railway, reference the managed Postgres service
# instead of pasting a literal: set this to  ${{ Postgres.DATABASE_URL }}
# (Railway substitutes the internal connection string at deploy time.)
DATABASE_URL=postgresql://user:password@host:5432/railway

# 32-byte key (64 hex chars) that encrypts/decrypts stored n8n API keys.
# CRITICAL: the SAME value MUST be set on web (which ENCRYPTS on save) and worker
# (which DECRYPTS when calling n8n). If they differ, ingestion can't read keys.
# Generate ONCE for production:   openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars_generated_for_production

# Log verbosity: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# WEB service only (Next.js)
# ----------------------------------------------------------------------------

# Better Auth session-signing secret. Generate fresh for production:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_a_long_random_secret_for_production

# Public URL of the deployed web app (Railway-provided domain or your custom
# domain). Drives OAuth callbacks and the CSRF trusted origin. No trailing slash.
# e.g. https://your-app.up.railway.app
BETTER_AUTH_URL=https://your-web-domain

# Google OAuth (OPTIONAL — email/password works without it). The button only
# activates when BOTH are set. In Google Cloud Console, the Authorized redirect
# URI must be exactly:  <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# WORKER service only (ingestion loop)
# ----------------------------------------------------------------------------

# How often (seconds) to poll each active n8n connection. (default: 30)
POLL_INTERVAL_SECONDS=30

# ----------------------------------------------------------------------------
# NOT needed in production (local-only — do not set on Railway)
# ----------------------------------------------------------------------------
# DB_USER / DB_PASSWORD / DB_NAME  — only used by local docker-compose Postgres;
#   in production the managed DATABASE_URL is the single source of truth.
# TEST_N8N_BASE_URL / TEST_N8N_API_KEY  — only used by local helper scripts.
